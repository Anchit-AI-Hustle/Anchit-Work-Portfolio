{
  "name": "anchit-portfolio",
  "version": "1.0.0",
  "description": "Anchit Tandon — Senior PM portfolio. Static web + PWA + native iOS/Android via Capacitor.",
  "private": true,
  "scripts": {
    "dev": "npx --yes serve@latest -l ${PORT:-5173} .",
    "build": "node scripts/build-www.mjs",
    "preview": "npx --yes serve@latest -l 4173 .",
    "tts:serve": "cd tts-server && .venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000",
    "cap:add:ios": "npm run build && npx cap add ios",
    "cap:add:android": "npm run build && npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:sync:android": "npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "yarn": "^1.22.22"
  },
  "engines": {
    "node": ">=18"
  }
}
