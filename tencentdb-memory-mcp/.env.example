# ---------------------------------------------------------------------------
# TencentDB Memory MCP — example environment
# Copy to `.env` and fill in. `scripts/setup-gateway.sh` auto-loads this file.
# ---------------------------------------------------------------------------

# --- Gateway location (used by BOTH the gateway and this MCP bridge) ---------
MEMORY_TENCENTDB_GATEWAY_HOST=127.0.0.1
MEMORY_TENCENTDB_GATEWAY_PORT=8420

# Full URL the MCP bridge dials. Defaults to http://127.0.0.1:8420 if unset.
TDAI_GATEWAY_URL=http://127.0.0.1:8420

# Optional bearer token if you protect the gateway. Leave blank for local use.
TDAI_GATEWAY_API_KEY=

# Stable identity for Claude Code's memory. Everything is namespaced by this.
TDAI_SESSION_KEY=claude-code

# --- LLM used by the gateway for distillation (L1/L2/L3) ---------------------
# Raw capture/recall work without these; persona/scene distillation needs them.
TDAI_LLM_API_KEY=sk-your-api-key-here
TDAI_LLM_BASE_URL=https://api.openai.com/v1
TDAI_LLM_MODEL=gpt-4o
