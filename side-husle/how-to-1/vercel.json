{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/how-to", "destination": "/how-to-2", "permanent": false },
    { "source": "/how-to/:path*", "destination": "/how-to-2/:path*", "permanent": false },
    { "source": "/how-to-1", "destination": "/how-to-2", "permanent": false },
    { "source": "/how-to-1/:path*", "destination": "/how-to-2/:path*", "permanent": false }
  ],
  "rewrites": [
    { "source": "/how-to-2/api/:fn*", "destination": "/api/:fn*" },
    { "source": "/how-to-2/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/how-to-2", "destination": "/index.html" },
    { "source": "/how-to-2/:path*", "destination": "/index.html" }
  ]
}
