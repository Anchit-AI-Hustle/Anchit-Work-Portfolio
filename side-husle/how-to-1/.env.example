# ── Server-side only (never exposed to the browser). Set these in your host's
#    environment (Vercel/Netlify project settings) or a local .env for `vercel dev`. ──

# Ranked model providers for the Agentic Cascade (add/remove freely).
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
XAI_API_KEY=...

# Text-to-video provider (choose one; the wrapper is provider-agnostic).
RUNWAY_API_KEY=...
LUMA_API_KEY=...

# Optional: force a single provider for local testing, or cap parallel fan-out.
CASCADE_MAX_PARALLEL=4
